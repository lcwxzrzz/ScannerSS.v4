def print_header(title):
    print()
    print(C.CYAN + "╔" + "═" * 50 + "╗" + C.RESET)
    print(C.CYAN + "║" + C.RESET + " " * 50 + C.CYAN + "║" + C.RESET)
    padding = (50 - len(title)) // 2
    print(C.CYAN + "║" + C.RESET + " " * padding + C.BRIGHT_CYAN + C.BOLD + title + C.RESET + " " * (50 - len(title) - padding) + C.CYAN + "║" + C.RESET)
    print(C.CYAN + "║" + C.RESET + " " * 50 + C.CYAN + "║" + C.RESET)
    print(C.CYAN + "╚" + "═" * 50 + "╝" + C.RESET)
    print()


def print_section(title):
    print()
    print(C.BRIGHT_BLUE + "┌" + "─" * 50 + "┐" + C.RESET)
    padding = (50 - len(title)) // 2
    print(C.BRIGHT_BLUE + "│" + C.RESET + " " * padding + C.BRIGHT_WHITE + C.BOLD + title + C.RESET + " " * (50 - len(title) - padding) + C.BRIGHT_BLUE + "│" + C.RESET)
    print(C.BRIGHT_BLUE + "└" + "─" * 50 + "┘" + C.RESET)
    print()


def print_category(name, color=C.BRIGHT_YELLOW):
    print(f"\n  {color}{C.BOLD}[ {name} ]{C.RESET}")
    print(f"  {color}{'─' * (len(name) + 4)}{C.RESET}")


def print_found(item, description="", level="warning"):
    if level == "critical":
        icon = C.BRIGHT_RED + "🔴" + C.RESET
        color = C.BRIGHT_RED
    elif level == "high":
        icon = C.RED + "⚠️ " + C.RESET
        color = C.RED
    elif level == "warning":
        icon = C.YELLOW + "⚠️ " + C.RESET
        color = C.YELLOW
    else:
        icon = C.GREEN + "✓" + C.RESET
        color = C.GREEN

    print(f"    {icon} {color}{item}{C.RESET}")
    if description:
        print(f"      {C.DIM}→ {description}{C.RESET}")


def print_ok(text):
    print(f"    {C.GREEN}✓ {text}{C.RESET}")


