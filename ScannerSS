    def check_adb(self):
        """Verifica se o ADB esta disponivel no PATH"""
        try:
            result = subprocess.run(['adb', 'version'], capture_output=True, text=True, timeout=5)
            if result.returncode == 0:
                return True
        except Exception:
            pass
        # Verificar se o binary existe em locais comuns do Termux
        adb_paths = [
            '/data/data/com.termux/files/usr/bin/adb',
            '/usr/bin/adb',
            '/bin/adb',
            '/system/bin/adb',
        ]
        for path in adb_paths:
            if os.path.exists(path) and os.access(path, os.X_OK):
                return True
        return False

    def run_adb(self, command):
        if not self.device_connected:
            return None
        try:
            full_cmd = ['adb', '-s', self.device_serial] + command
            result = subprocess.run(full_cmd, capture_output=True, text=True, timeout=30)
            return result
        except Exception as e:
            print_error(f"Erro no comando ADB: {e}")
            return None

    def check_root_device(self):
        result = self.run_adb(['shell', 'su', '-c', 'id'])
        if result and result.returncode == 0:
            self.has_root = True
            print_found("ROOT DETECTADO", "Dispositivo tem acesso root total", "critical")
            return True
        else:
            self.has_root = False
            print_info("Dispositivo sem ROOT (acesso limitado)")
            return False

    def pair_device(self):
        clear()
        print_header("PAREAR DISPOSITIVO")
        if not self.check_adb():
            print_error("ADB nao encontrado!")
            print_info("Tentando instalar ADB...")
            print_info("Metodo 1: pkg install android-tools...")
            r1 = os.system("pkg install android-tools -y 2>/dev/null")
            if not self.check_adb():
                print_info("Metodo 2: apt install android-tools...")
                r2 = os.system("apt update -y >/dev/null 2>&1 && apt install android-tools -y 2>/dev/null")
                if not self.check_adb():
                    print_info("Metodo 3: apt-get install android-tools...")
                    r3 = os.system("apt-get update -y >/dev/null 2>&1 && apt-get install android-tools -y 2>/dev/null")
                    if not self.check_adb():
                        print_error("Falha ao instalar ADB automaticamente!")
                        print_info("Tente manualmente com um dos comandos:")
                        print(f"  {C.CYAN}pkg install android-tools -y{C.RESET}")
                        print(f"  {C.CYAN}apt install android-tools -y{C.RESET}")
                        print(f"  {C.CYAN}apt-get install android-tools -y{C.RESET}")
                        print_info("Ou verifique se o mirror do Termux esta configurado:")
                        print(f"  {C.CYAN}termux-change-repo{C.RESET}")
                        pause()
                        return False
                    else:
                        print_found("ADB instalado via apt-get!", "", "high")
                else:
                    print_found("ADB instalado via apt!", "", "high")
            else:
                print_found("ADB instalado via pkg!", "", "high")

        print_info("Verificando dispositivos conectados...")
        print()
        result = subprocess.run(['adb', 'devices'], capture_output=True, text=True)
        lines = result.stdout.strip().split('\n')
        devices = []
        for line in lines[1:]:
            if '\t' in line:
                parts = line.split('\t')
                if len(parts) >= 2:
                    serial = parts[0].strip()
                    status = parts[1].strip()
                    devices.append((serial, status))

        if not devices:
            print_info("Nenhum dispositivo USB conectado.")
            print()
            print_info("Tentando conexao via WiFi...")
            print(f"  {C.WHITE}Digite o IP do dispositivo (ex: 192.168.1.100:5555){C.RESET}")
            print(f"  {C.WHITE}ou pressione ENTER para cancelar:{C.RESET}")
            ip = input(f"  {C.CYAN}> {C.RESET}").strip()
            if ip:
                print_info(f"Conectando a {ip}...")
                result = subprocess.run(['adb', 'connect', ip], capture_output=True, text=True)
                if "connected" in result.stdout.lower() or "already" in result.stdout.lower():
                    print_found("Conectado com sucesso!", "", "high")
                    self.device_connected = True
                    self.device_serial = ip
                    pause()
                    return True
                else:
                    print_error("Falha na conexao")
                    print(f"  {C.DIM}{result.stdout}{C.RESET}")
                    pause()
                    return False
            else:
                print_info("Conexao cancelada.")
                pause()
                return False
        else:
            print_found(f"{len(devices)} dispositivo(s) encontrado(s)", "", "high")
            for i, (serial, status) in enumerate(devices):
                color = C.GREEN if status == "device" else C.YELLOW
                print(f"    [{i+1}] {color}{serial}{C.RESET} - {status}")
            print()
            print_info("Selecione o dispositivo (numero) ou ENTER para o primeiro:")
            choice = input(f"  {C.CYAN}> {C.RESET}").strip()
            try:
                idx = int(choice) - 1 if choice else 0
                if 0 <= idx < len(devices):
                    self.device_serial = devices[idx][0]
                    self.device_connected = True
                    print_found(f"Dispositivo selecionado: {self.device_serial}", "", "high")
                    self.check_root_device()
                    pause()
                    return True
            except:
                pass
            print_error("Selecao invalida.")
            pause()
            return False

