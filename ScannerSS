    def _show_progress(self, current, total, label, width=40):
        """Mostra uma barra de progresso animada"""
        progress = int((current / total) * width) if total > 0 else width
        empty = width - progress
        bar = C.BRIGHT_GREEN + "█" * progress + C.DIM + "░" * empty + C.RESET
        percent = int((current / total) * 100) if total > 0 else 100
        print(f"\r  [{bar}] {C.BRIGHT_GREEN}{C.BOLD}{percent}%{C.RESET} | {label[:40]}", end="", flush=True)

    def _finish_progress(self, width=40):
        """Finaliza a barra de progresso em 100%"""
        bar = C.BRIGHT_GREEN + "█" * width + C.RESET
        print(f"\r  [{bar}] {C.BRIGHT_GREEN}{C.BOLD}100%{C.RESET} | {C.GREEN}Concluido!{C.RESET}          ")
        print()

    def _check_root_status(self):
