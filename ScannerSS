    def main(self):
        while True:
            self.show_dragon()
            print_header("FireDragon Scanner v4.0")
            self.show_main_menu()
            try:
                choice = input().strip().lower()
            except (EOFError, KeyboardInterrupt):
                print()
                break
            if choice == '0':
                self.pair_device()
            elif choice == '1':
                if self.device_connected:
                    self.scan_ff(FF_PACKAGE, "FreeFire Normal")
                else:
                    print(f"\n  {C.RED}✗ Pareie um dispositivo primeiro!{C.RESET}")
                    time.sleep(1.5)
            elif choice == '2':
                if self.device_connected:
                    self.scan_ff(FF_PACKAGE_MAX, "FreeFire Max")
                else:
                    print(f"\n  {C.RED}✗ Pareie um dispositivo primeiro!{C.RESET}")
                    time.sleep(1.5)
            elif choice == '3':
                if self.device_connected:
                    self.save_dump()
                else:
                    print(f"\n  {C.RED}✗ Pareie um dispositivo primeiro!{C.RESET}")
                    time.sleep(1.5)
            elif choice == 's':
                clear()
                print()
                print_header("Obrigado por usar o FireDragon Scanner v4.0!")
                print()
                break
            else:
                print(f"\n  {C.RED}✗ Opcao invalida!{C.RESET}")
                time.sleep(1)


