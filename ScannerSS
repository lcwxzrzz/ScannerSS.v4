        if result and result.returncode == 0:
            print_found("Magisk detectado", "Framework de root ativo no dispositivo", "critical")
            self.has_root = True

        result = self.run_adb(['shell', 'ls', '/data/data/com.koushikdutta.superuser'])
        if result and result.returncode == 0:
            print_found("SuperSU detectado", "App de gerenciamento root encontrado", "critical")
            self.has_root = True

