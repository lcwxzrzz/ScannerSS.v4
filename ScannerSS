    def _calculate_wo_score(self):
        """Calcula a pontuacao de risco para W.O"""
        score = 0
        max_score = 100

        # ROOT (peso alto)
        if self.has_root:
            score += 15

        # Apps suspeitos encontrados
        score += len(self.suspects_found) * 2

        # Warnings
        score += len(self.warnings) * 3

        # Dominios suspeitos (peso muito alto)
        score += len(self.domains_found) * 4

        # Script apps
        score += len(self.script_apps_found) * 3

        # Memory mods (peso critico)
        score += len(self.memory_mods_found) * 5

        # Injector apps (peso critico)
        score += len(self.injector_apps_found) * 5

        # Apps ocultos
        score += len(self.hidden_apps_found) * 4

        # Bibliotecas modificadas
        score += len(self.modified_libs_found) * 4

        # Permissoes suspeitas
        score += len(self.suspicious_permissions) * 2

        # Anomalias de rede
        score += len(self.network_anomalies) * 2

        # Wall of shame
        score += len(self.wall_of_shame) * 5

        # Telegram cheats
        score += len(self.telegram_cheats) * 3

        # Floating windows
        score += len(self.floating_windows) * 4

        # Clipboard cheats
        score += len(self.clipboard_cheats) * 3

        # DNS anomalies
        score += len(self.dns_anomalies) * 2

        # Hosts modifications
        score += len(self.hosts_modifications) * 4

        # Magisk modules
        score += len(self.magisk_modules) * 3

        # ZArchiver apps
        score += len(self.zarchiver_apps) * 1

        # Chrome apps
        score += len(self.chrome_apps) * 1

        # Limitar a 100
        percentage = min(score, max_score)
        return percentage

